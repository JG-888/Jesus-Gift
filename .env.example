# Copy this file to `.env` and fill in real values locally.
# `.env` is gitignored and must NEVER be committed or shared.

# Trading Platform API Credentials
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_PASSPHRASE=

# Claude API (for Routines)
CLAUDE_API_KEY=

# Trading Parameters
EXCHANGE_SANDBOX=true
SYMBOL=BTC/USD
TIMEFRAME=1m

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
