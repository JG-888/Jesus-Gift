# Copy this file to `.env` and fill in real values LOCALLY.
# `.env` is gitignored and must NEVER be committed or shared.
# If the agent runs as a REMOTE routine, put these in that platform's secret
# store (not a local file) — same names, different home.

# --- Broker: TradeZero ---
# (match these to whatever your TradeZero API client expects)
TRADEZERO_USERNAME=
TRADEZERO_PASSWORD=
TRADEZERO_API_KEY=

# --- Claude API (drives the routine) ---
CLAUDE_API_KEY=

# --- GitHub: the agent's access to THIS private memory repo ---
# Fine-grained Personal Access Token scoped to ONLY JG-888/Jesus-Gift,
# with repository permission "Contents: Read and write".
GITHUB_TOKEN=

# --- Runtime ---
TRADING_MODE=paper        # paper | live  — start on paper
LOG_LEVEL=INFO
LOG_DIR=./logs
